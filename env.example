# RFPO Application Environment Variables

# =============================================================================
# SECRET KEYS (Required — change ALL of these in production!)
# =============================================================================
JWT_SECRET_KEY=jwt-secret-key-change-in-production
API_SECRET_KEY=api-secret-key-change-in-production
USER_APP_SECRET_KEY=user-app-secret-change-in-production
ADMIN_SECRET_KEY=admin-secret-key-change-in-production

# =============================================================================
# DATABASE
# =============================================================================
# SQLite (local): sqlite:///instance/rfpo_admin.db
# PostgreSQL (Azure): postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=sqlite:///instance/rfpo_admin.db

# =============================================================================
# FLASK
# =============================================================================
FLASK_ENV=development

# =============================================================================
# SERVICE URLs (used by User App to reach API and Admin)
# =============================================================================
API_BASE_URL=http://127.0.0.1:5002/api
ADMIN_API_URL=http://127.0.0.1:5111/api
USER_APP_URL=http://127.0.0.1:5000

# =============================================================================
# CORS (comma-separated origins, or * for development)
# =============================================================================
CORS_ORIGINS=http://localhost:5000,http://localhost:5111

# =============================================================================
# EMAIL — Azure Communication Services (preferred)
# =============================================================================
ACS_CONNECTION_STRING=
ACS_SENDER_EMAIL=no-reply@example.com

# =============================================================================
# EMAIL — SMTP fallback (optional, used if ACS is not configured)
# =============================================================================
MAIL_SERVER=localhost
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@localhost

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=3

# =============================================================================
# SECURITY (production defaults)
# =============================================================================
FORCE_HTTPS=False
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PASSWORD_MIN_LENGTH=12
PASSWORD_MAX_LENGTH=128
LOGIN_ATTEMPT_LIMIT=5
ACCOUNT_LOCKOUT_MINUTES=30

# =============================================================================
# FILE UPLOADS
# =============================================================================
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=csv,xlsx,xls

# =============================================================================
# SAML SSO (provided by identity provider)
# =============================================================================
SAML_ENABLED=false
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_SLS_URL=
SAML_IDP_X509_CERT=
SAML_SP_ENTITY_ID=https://rfpo.uscar.org
SAML_SP_ACS_URL=https://rfpo.uscar.org/saml/acs
SAML_SP_SLS_URL=https://rfpo.uscar.org/saml/sls


