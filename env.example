# RFPO Application Environment Variables

# JWT Secret Key (change in production)
JWT_SECRET_KEY=jwt-secret-key-change-in-production

# API Secret Key (change in production)
API_SECRET_KEY=api-secret-key-change-in-production

# User App Secret Key (change in production)
USER_APP_SECRET_KEY=user-app-secret-change-in-production

# Admin Secret Key (change in production)
ADMIN_SECRET_KEY=admin-secret-key-change-in-production

# Database URL (SQLite by default)
DATABASE_URL=sqlite:///instance/rfpo_admin.db

# Flask Environment
FLASK_ENV=development


# Azure Communication Services (Email)
# Connection string copied from the Azure Communication Services resource
ACS_CONNECTION_STRING=
# Verified sender email address/domain configured in ACS
ACS_SENDER_EMAIL=no-reply@example.com

# SAML SSO Configuration (provided by USCAR IT)
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_SLS_URL=
SAML_IDP_X509_CERT=
SAML_SP_ENTITY_ID=https://rfpo-user.livelyforest-d06a98a0.eastus.azurecontainerapps.io
SAML_SP_ACS_URL=https://rfpo-user.livelyforest-d06a98a0.eastus.azurecontainerapps.io/saml/acs
SAML_SP_SLS_URL=https://rfpo-user.livelyforest-d06a98a0.eastus.azurecontainerapps.io/saml/sls
SAML_ENABLED=false


